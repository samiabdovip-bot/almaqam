            <!-- الجدول الرئيسي -->
            <div class="table-section">
                <table class="responsive-table" id="invoiceTable">
                    <thead class="table-header">
                        <tr>
                            <th>الصنف</th>
                            <th>المقاس 54</th>
                            <th>المقاس 56</th>
                            <th>المقاس 58</th>
                            <th>المقاس 60</th>
                            <th>المقاس 62</th>
                            <th>المقاس 64</th>
                            <th>الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody id="invoiceItems">
                        <!-- سيتم ملؤها بواسطة الجافاسكريبت -->
                    </tbody>
                </table>
            </div>
            
            <!-- ملخص الطلب -->
            <div class="summary-section">
                <div class="summary-content">
                    <div class="grand-total">
                        <div class="total-label">الإجمالي الكلي للتجهيز</div>
                        <div class="total-value">
                            <span id="grandTotal">0</span>
                            <span style="font-size: 24px;"> قطعة</span>
