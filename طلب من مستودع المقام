<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مؤسسة المقام - نظام طلبات التوريد 2026</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root {
            --primary: #1a237e;
            --primary-light: #534bae;
            --primary-dark: #000051;
            --accent: #d32f2f;
            --success: #388e3c;
            --warning: #f57c00;
            --light: #f5f7ff;
            --dark: #1a1a2e;
            --add-color: #9c27b0;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', 'Tahoma', 'Arial', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #333;
            line-height: 1.6;
            padding: 20px;
            min-height: 100vh;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .app-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            margin-bottom: 30px;
        }
        
        .app-header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            padding: 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        .app-header::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%);
            animation: shimmer 3s infinite;
        }
        
        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
        
        .logo {
            font-size: 48px;
            margin-bottom: 15px;
            position: relative;
            z-index: 1;
        }
        
        .app-title {
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 10px;
            position: relative;
            z-index: 1;
        }
        
        .app-subtitle {
            font-size: 18px;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }
        
        .customer-info {
            padding: 30px;
            background: var(--light);
            border-bottom: 3px solid var(--primary);
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }
        
        .input-group {
            display: flex;
            flex-direction: column;
        }
        
        .input-label {
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 10px;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .input-label.required::after {
            content: " *";
            color: var(--accent);
            font-weight: bold;
        }
        
        .input-field {
            padding: 15px;
            border: 2px solid #d1d9ff;
            border-radius: 10px;
            font-size: 18px;
            background: white;
            transition: all 0.3s ease;
        }
        
        .input-field.required-field:invalid {
            border-color: #ff9800;
            background-color: #fff8e1;
        }
        
        .input-field:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(26, 35, 126, 0.2);
        }
        
        .input-field:invalid:not(:focus):not(:placeholder-shown) {
            border-color: var(--accent);
            background-color: #ffebee;
        }
        
        .table-section {
            padding: 30px;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
        
        .responsive-table {
            width: 100%;
            min-width: 800px;
            border-collapse: collapse;
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            font-size: 14px;
        }
        
        .table-header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
        }
        
        .table-header th {
            padding: 20px 15px;
            font-weight: 700;
            text-align: center;
            border-left: 1px solid rgba(255, 255, 255, 0.2);
            font-size: 16px;
        }
        
        .table-header th:first-child {
            border-left: none;
            min-width: 180px;
        }
        
        .product-row {
            transition: all 0.3s ease;
            border-bottom: 1px solid #f0f0f0;
        }
        
        .product-row:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .product-name {
            font-weight: 800;
            color: var(--primary-dark);
            padding: 20px 15px;
            text-align: center;
            border-right: 3px solid var(--primary);
            font-size: 16px;
            position: relative;
        }
        
        .size-cell {
            padding: 10px 5px;
            text-align: center;
        }
        
        .size-input-group {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            padding: 5px;
        }
        
        .size-label {
            font-size: 11px;
            font-weight: 700;
            color: #5d6d97;
            background: #eef1f9;
            padding: 3px 8px;
            border-radius: 4px;
            width: 100%;
            text-align: center;
        }
        
        .quantity-controls {
            display: flex;
            align-items: center;
            gap: 5px;
            width: 100%;
            justify-content: center;
        }
        
        .quantity-btn {
            width: 35px;
            height: 35px;
            border: none;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
            flex-shrink: 0;
        }
        
        .quantity-btn:hover {
            background: var(--primary-dark);
            transform: scale(1.1);
        }
        
        .quantity-btn:active {
            transform: scale(0.95);
        }
        
        .quantity-btn.minus {
            background: #d32f2f;
        }
        
        .quantity-btn.minus:hover {
            background: #b71c1c;
        }
        
        .quantity-btn.plus {
            background: #388e3c;
        }
        
        .quantity-btn.plus:hover {
            background: #2e7d32;
        }
        
        .quantity-input {
            width: 60px;
            padding: 8px 5px;
            border: 2px solid #d1d9ff;
            border-radius: 8px;
            text-align: center;
            font-size: 16px;
            font-weight: 700;
            color: var(--primary);
            background: white;
            transition: all 0.2s ease;
        }
        
        .quantity-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 2px rgba(26, 35, 126, 0.1);
        }
        
        .quantity-input::-webkit-inner-spin-button,
        .quantity-input::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        
        .total-cell {
            font-weight: 900;
            color: var(--accent);
            text-align: center;
            font-size: 20px;
            padding: 20px 15px;
        }
        
        .summary-section {
            padding: 30px;
            background: linear-gradient(135deg, #f8fbff 0%, #f0f7ff 100%);
            border-top: 3px double var(--primary);
        }
        
        .summary-content {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 30px;
        }
        
        .grand-total {
            background: linear-gradient(135deg, #fff9e6 0%, #ffe680 100%);
            padding: 25px 50px;
            border-radius: 15px;
            border: 3px solid var(--primary);
            text-align: center;
            min-width: 300px;
            box-shadow: 0 5px 20px rgba(255, 193, 7, 0.2);
        }
        
        .total-label {
            font-size: 20px;
            font-weight: 700;
            color: var(--primary-dark);
            margin-bottom: 10px;
        }
        
        .total-value {
            font-size: 40px;
            font-weight: 900;
            color: var(--accent);
        }
        
        .action-buttons {
            padding: 40px 30px;
            text-align: center;
            background: var(--light);
        }
        
        .buttons-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            max-width: 800px;
            margin: 0 auto;
        }
        
        .action-btn {
            padding: 20px 40px;
            border: none;
            border-radius: 15px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            min-width: 220px;
        }
        
        .action-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }
        
        .action-btn:active {
            transform: translateY(0);
        }
        
        .btn-pdf {
            background: linear-gradient(135deg, var(--accent) 0%, #b71c1c 100%);
            color: white;
        }
        
        .btn-whatsapp {
            background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
            color: white;
        }
        
        .btn-reset {
            background: linear-gradient(135deg, #78909c 0%, #546e7a 100%);
            color: white;
        }
        
        .btn-add-item {
            background: linear-gradient(135deg, var(--add-color) 0%, #7b1fa2 100%);
            color: white;
        }
        
        .btn-edit-item {
            background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
            color: white;
            padding: 8px 15px;
            font-size: 14px;
            border-radius: 8px;
            margin-top: 5px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        
        .btn-remove-item {
            background: linear-gradient(135deg, #f44336 0%, #c62828 100%);
            color: white;
            padding: 8px 15px;
            font-size: 14px;
            border-radius: 8px;
            margin-top: 5px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        
        .item-actions {
            display: flex;
            gap: 5px;
            justify-content: center;
            margin-top: 10px;
        }
        
        .status-bar {
            position: fixed;
            top: 20px;
            right: 20px;
            left: 20px;
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            gap: 15px;
            z-index: 1000;
            transform: translateY(-150%);
            transition: transform 0.4s ease;
            max-width: 500px;
            margin: 0 auto;
        }
        
        .status-bar.show {
            transform: translateY(0);
        }
        
        .status-icon {
            font-size: 28px;
            flex-shrink: 0;
        }
        
        .status-message {
            flex: 1;
            font-weight: 600;
            font-size: 16px;
        }
        
        .status-close {
            background: none;
            border: none;
            font-size: 24px;
            color: #999;
            cursor: pointer;
            padding: 5px;
        }
        
        /* نافذة إدارة الأصناف */
        .modal-overlay {
            position: fixed;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            padding: 20px;
        }
        
        .modal-content {
            background: white;
            border-radius: 20px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            animation: modalAppear 0.3s ease;
        }
        
        @keyframes modalAppear {
            0% { transform: translateY(-20px) scale(0.95); opacity: 0; }
            100% { transform: translateY(0) scale(1); opacity: 1; }
        }
        
        .modal-header {
            background: linear-gradient(135deg, var(--add-color) 0%, #7b1fa2 100%);
            color: white;
            padding: 25px;
            text-align: center;
        }
        
        .modal-header h2 {
            font-size: 24px;
            margin: 0;
            font-weight: 800;
        }
        
        .modal-body {
            padding: 30px;
        }
        
        .modal-footer {
            padding: 20px 30px;
            background: #f8f9ff;
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            border-top: 1px solid #e0e0e0;
        }
        
        .modal-btn {
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .modal-btn-primary {
            background: linear-gradient(135deg, var(--add-color) 0%, #7b1fa2 100%);
            color: white;
        }
        
        .modal-btn-secondary {
            background: #f5f5f5;
            color: #666;
        }
        
        .modal-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }
        
        /* ألوان متدرجة للتمييز بين الأصناف */
        .gradient-1 { background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%); }
        .gradient-2 { background: linear-gradient(135deg, #fce4ec 0%, #f8bbd9 100%); }
        .gradient-3 { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); }
        .gradient-4 { background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%); }
        .gradient-5 { background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%); }
        .gradient-6 { background: linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%); }
        .gradient-7 { background: linear-gradient(135deg, #f9fbe7 0%, #f0f4c3 100%); }
        .gradient-8 { background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%); }
        .gradient-9 { background: linear-gradient(135deg, #e8eaf6 0%, #9fa8da 100%); }
        .gradient-10 { background: linear-gradient(135deg, #fce4ec 0%, #f48fb1 100%); }
        .gradient-11 { background: linear-gradient(135deg, #e1f5fe 0%, #81d4fa 100%); }
        .gradient-12 { background: linear-gradient(135deg, #f3e5f5 0%, #ce93d8 100%); }
        
        /* زر خيارات الواتساب */
        .whatsapp-options {
            display: none;
            position: absolute;
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            padding: 15px;
            z-index: 100;
            min-width: 250px;
            margin-top: 10px;
            right: 0;
        }
        
        .whatsapp-options.show {
            display: block;
        }
        
        .whatsapp-option {
            padding: 12px;
            border: none;
            background: #f5f5f5;
            border-radius: 8px;
            width: 100%;
            text-align: center;
            margin-bottom: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
        }
        
        .whatsapp-option:hover {
            background: #25D366;
            color: white;
            transform: translateY(-2px);
        }
        
        .whatsapp-btn-container {
            position: relative;
        }
        
        /* تذييل الحقول الإلزامية */
        .field-note {
            font-size: 12px;
            color: #666;
            margin-top: 5px;
            text-align: right;
        }
        
        .required-note {
            font-size: 13px;
            color: var(--accent);
            margin-top: 15px;
            padding: 10px;
            background: #ffebee;
            border-radius: 8px;
            border-right: 3px solid var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        @media (max-width: 768px) {
            body {
                padding: 10px;
            }
            
            .app-header {
                padding: 20px 15px;
            }
            
            .logo {
                font-size: 36px;
            }
            
            .app-title {
                font-size: 24px;
            }
            
            .app-subtitle {
                font-size: 16px;
            }
            
            .customer-info {
                padding: 20px;
            }
            
            .info-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            
            .table-section {
                padding: 15px;
            }
            
            .responsive-table {
                font-size: 12px;
            }
            
            .table-header th {
                padding: 15px 10px;
                font-size: 14px;
            }
            
            .product-name {
                padding: 15px 10px;
                font-size: 14px;
            }
            
            .size-label {
                font-size: 10px;
                padding: 2px 6px;
            }
            
            .quantity-btn {
                width: 30px;
                height: 30px;
                font-size: 16px;
            }
            
            .quantity-input {
                width: 50px;
                padding: 6px 4px;
                font-size: 14px;
            }
            
            .total-cell {
                font-size: 18px;
                padding: 15px 10px;
            }
            
            .grand-total {
                min-width: 100%;
                padding: 20px;
            }
            
            .total-value {
                font-size: 32px;
            }
            
            .action-buttons {
                padding: 20px 15px;
            }
            
            .action-btn {
                padding: 15px 25px;
                font-size: 16px;
                min-width: 100%;
            }
            
            .buttons-container {
                flex-direction: column;
                gap: 15px;
            }
            
            .status-bar {
                top: 10px;
                right: 10px;
                left: 10px;
                padding: 15px;
            }
            
            .modal-content {
                max-width: 95%;
            }
            
            .modal-body {
                padding: 20px;
            }
            
            .modal-footer {
                padding: 15px 20px;
                flex-direction: column;
            }
            
            .modal-btn {
                width: 100%;
            }
            
            .item-actions {
                flex-direction: column;
                gap: 5px;
            }
            
            .whatsapp-options {
                min-width: 200px;
                right: 0;
                left: 0;
                margin: 10px auto;
            }
        }
        
        @media print {
            body {
                background: white !important;
                padding: 0 !important;
            }
            
            .app-card {
                box-shadow: none !important;
                border-radius: 0 !important;
            }
            
            .action-buttons,
            .status-bar,
            .item-actions,
            .modal-overlay {
                display: none !important;
            }
            
            .quantity-input {
                border: 1px solid #ccc !important;
            }
            
            .quantity-btn {
                display: none !important;
            }
        }
        
        .table-section::-webkit-scrollbar {
            height: 8px;
        }
        
        .table-section::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }
        
        .table-section::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 4px;
        }
        
        .table-section::-webkit-scrollbar-thumb:hover {
            background: var(--primary-light);
        }
        
        @media (hover: none) and (pointer: coarse) {
            .quantity-input {
                min-height: 40px;
                font-size: 16px;
            }
            
            .action-btn {
                min-height: 44px;
            }
        }
    </style>
</head>
<body>
    <!-- شريط الحالة -->
    <div class="status-bar" id="statusBar">
        <div class="status-icon" id="statusIcon">
            <i class="fas fa-info-circle"></i>
        </div>
        <div class="status-message" id="statusMessage">
            جاري تحميل النظام...
        </div>
        <button class="status-close" onclick="hideStatus()">
            <i class="fas fa-times"></i>
        </button>
    </div>
    
    <!-- نافذة إدارة الأصناف -->
    <div class="modal-overlay" id="editItemModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="modalTitle"><i class="fas fa-plus-circle"></i> إدارة الأصناف</h2>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editItemIndex" value="-1">
                
                <div class="input-group" style="margin-bottom: 20px;">
                    <label class="input-label">
                        <i class="fas fa-tag"></i>
                        اسم الصنف
                    </label>
                    <input type="text" id="editItemName" class="input-field" placeholder="أدخل اسم الصنف" required>
                </div>
                
                <div class="input-group" style="margin-bottom: 20px;">
                    <label class="input-label">
                        <i class="fas fa-code"></i>
                        رمز الصنف
                    </label>
                    <input type="text" id="editItemCode" class="input-field" placeholder="أدخل رمز مختصر للصنف" required>
                    <small style="color: #666; margin-top: 5px;">يستخدم للتمييز في التقارير</small>
                </div>
                
                <div class="input-group" style="margin-bottom: 20px;">
                    <label class="input-label">
                        <i class="fas fa-palette"></i>
                        تدرج اللون للتمييز
                    </label>
                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 10px;">
                        <div class="color-option" data-color="gradient-1" onclick="selectColor('gradient-1')" style="background: linear-gradient(135deg, #e8eaf6 0%, #c5cae9 100%); height: 40px; border-radius: 8px; cursor: pointer; border: 2px solid transparent;"></div>
                        <div class="color-option" data-color="gradient-2" onclick="selectColor('gradient-2')" style="background: linear-gradient(135deg, #fce4ec 0%, #f8bbd9 100%); height: 40px; border-radius: 8px; cursor: pointer; border: 2px solid transparent;"></div>
                        <div class="color-option" data-color="gradient-3" onclick="selectColor('gradient-3')" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); height: 40px; border-radius: 8px; cursor: pointer; border: 2px solid transparent;"></div>
                        <div class="color-option" data-color="gradient-4" onclick="selectColor('gradient-4')" style="background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%); height: 40px; border-radius: 8px; cursor: pointer; border: 2px solid transparent;"></div>
                        <div class="color-option" data-color="gradient-5" onclick="selectColor('gradient-5')" style="background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%); height: 40px; border-radius: 8px; cursor: pointer; border: 2px solid transparent;"></div>
                        <div class="color-option" data-color="gradient-6" onclick="selectColor('gradient-6')" style="background: linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%); height: 40px; border-radius: 8px; cursor: pointer; border: 2px solid transparent;"></div>
                        <div class="color-option" data-color="gradient-7" onclick="selectColor('gradient-7')" style="background: linear-gradient(135deg, #f9fbe7 0%, #f0f4c3 100%); height: 40px; border-radius: 8px; cursor: pointer; border: 2px solid transparent;"></div>
                        <div class="color-option" data-color="gradient-8" onclick="selectColor('gradient-8')" style="background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%); height: 40px; border-radius: 8px; cursor: pointer; border: 2px solid transparent;"></div>
                    </div>
                    <input type="hidden" id="selectedColor" value="gradient-1">
                </div>
            </div>
            <div class="modal-footer">
                <button class="modal-btn modal-btn-secondary" onclick="closeEditItemModal()">
                    <i class="fas fa-times"></i> إلغاء
                </button>
                <button class="modal-btn modal-btn-primary" onclick="saveItem()">
                    <i class="fas fa-save"></i> حفظ التغييرات
                </button>
            </div>
        </div>
