                </div>
                <h1 class="app-title">مؤسسة المقام التجارية</h1>
                <p class="app-subtitle">نظام طلبات التوريد المعتمد - 2026</p>
            </div>
            
            <!-- معلومات العميل -->
            <div class="customer-info">
                <div class="info-grid">
                    <div class="input-group">
                        <label class="input-label required">
                            <i class="fas fa-user"></i>
                            اسم العميل
                        </label>
                        <input type="text" id="custName" class="input-field required-field" placeholder="أدخل اسم العميل الكامل" required>
                        <div class="field-note">مطلوب</div>
