                        </label>
                        <input type="text" id="custAddress" class="input-field required-field" placeholder="أدخل العنوان التفصيلي" required>
                        <div class="field-note">مطلوب</div>
                    </div>
                    
                    <div class="input-group">
                        <label class="input-label required">
                            <i class="fas fa-user-tie"></i>
                            اسم المندوب
                        </label>
                        <input type="text" id="repName" class="input-field required-field" placeholder="اسم المندوب المرسل للطلب" required>
