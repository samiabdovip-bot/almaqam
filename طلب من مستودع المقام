    <script>
        // البيانات الأساسية
        let itemsData = [
            {name: "ملون سادة A", code: "A", colorClass: "gradient-1", isCustom: false},
            {name: "سحاب سادة ZA", code: "ZA", colorClass: "gradient-2", isCustom: false},
            {name: "سحاب كبك ZC", code: "ZC", colorClass: "gradient-3", isCustom: false},
            {name: "سحاب قلاب سادة ZD", code: "ZD", colorClass: "gradient-4", isCustom: false},
            {name: "سحاب قلاب كبك ZB", code: "ZB", colorClass: "gradient-5", isCustom: false},
            {name: "سادة كبك C", code: "C", colorClass: "gradient-6", isCustom: false},
            {name: "قلاب سادة B", code: "B", colorClass: "gradient-7", isCustom: false},
            {name: "قلاب فرنسي", code: "FR", colorClass: "gradient-8", isCustom: false}
        ];
        
        const sizes = ["54", "56", "58", "60", "62", "64"];
        const subSizes = ["S", "M", "L", "XL", "2XL", "3XL"];
        
        // حالة التطبيق
        let appState = {
            customerName: "",
            customerAddress: "",
            representative: "",
            phone: "",
            lastSave: null,
            quantities: {},
            customItems: []
        };
        
        // تهيئة التطبيق
        document.addEventListener('DOMContentLoaded', function() {
            initializeApp();
        });
        
        function initializeApp() {
            // تعيين التاريخ الميلادي
            setGregorianDate();
            
            // تحميل البيانات المحفوظة
            loadSavedData();
            
            // بناء الجدول
            buildTable();
            
            // إضافة مستمعي الأحداث
            setupEventListeners();
            
            // التحقق من الحقول المطلوبة
            validateRequiredFields();
            
            // إظهار رسالة الترحيب
            showStatus("مرحباً بك في نظام طلبات مؤسسة المقام", "success");
        }
        
        // تعيين التاريخ الميلادي
        function setGregorianDate() {
            const today = new Date();
            const arabicDate = today.toLocaleDateString('ar-EG', {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });
            document.getElementById('displayDate').textContent = arabicDate;
        }
        
        // بناء الجدول مع تدرج الألوان للصف كامل
        function buildTable() {
            const tbody = document.getElementById('invoiceItems');
            tbody.innerHTML = '';
            
            itemsData.forEach((item, rowIndex) => {
                const row = document.createElement('tr');
                row.className = `product-row ${item.colorClass}`;
                row.id = `row-${rowIndex}`;
                row.dataset.itemId = item.code;
                
                // خلية اسم المنتج
                const nameCell = document.createElement('td');
                nameCell.className = 'product-name';
                
                let nameCellContent = `
                    <div style="font-weight: 800; font-size: 16px; color: #1a237e;">${item.name}</div>
                    <div style="font-size: 12px; color: #666; margin-top: 5px;">${item.code}</div>
                    <div class="item-actions">
                        <button class="btn-edit-item" onclick="openEditItemModal(${rowIndex})" title="تعديل الصنف">
                            <i class="fas fa-edit"></i> تعديل
                        </button>
                        <button class="btn-remove-item" onclick="removeItem(${rowIndex})" title="حذف الصنف">
                            <i class="fas fa-trash"></i> حذف
                        </button>
                    </div>
                `;
                
                nameCell.innerHTML = nameCellContent;
                row.appendChild(nameCell);
                
                // خلايا المقاسات
                sizes.forEach((size, sizeIndex) => {
                    const sizeCell = document.createElement('td');
                    sizeCell.className = 'size-cell';
                    
                    const sizeInputs = document.createElement('div');
                    sizeInputs.className = 'size-input-group';
                    
                    subSizes.forEach((subSize, subIndex) => {
                        const inputId = `qty-${rowIndex}-${size}-${subSize}`;
                        const savedValue = appState.quantities[inputId] || '';
                        
                        const sizeLabel = document.createElement('div');
                        sizeLabel.className = 'size-label';
                        sizeLabel.textContent = `${size}-${subSize}`;
                        
                        const controlsContainer = document.createElement('div');
                        controlsContainer.className = 'quantity-controls';
                        
                        // زر الناقص
                        const minusBtn = document.createElement('button');
                        minusBtn.type = 'button';
                        minusBtn.className = 'quantity-btn minus';
                        minusBtn.innerHTML = '<i class="fas fa-minus"></i>';
                        minusBtn.onclick = function() {
                            adjustQuantity(inputId, -1);
                        };
                        
                        // حقل الإدخال
                        const input = document.createElement('input');
                        input.type = 'number';
                        input.id = inputId;
                        input.className = 'quantity-input';
                        input.min = '0';
                        input.value = savedValue;
                        input.dataset.row = rowIndex;
                        input.dataset.size = size;
                        input.dataset.sub = subSize;
                        input.placeholder = '0';
                        
                        // إضافة مستمعي الأحداث
                        input.addEventListener('input', handleQuantityInput);
                        input.addEventListener('change', saveData);
                        input.addEventListener('focus', function() { this.select(); });
                        
                        // زر الزائد
                        const plusBtn = document.createElement('button');
                        plusBtn.type = 'button';
                        plusBtn.className = 'quantity-btn plus';
                        plusBtn.innerHTML = '<i class="fas fa-plus"></i>';
                        plusBtn.onclick = function() {
                            adjustQuantity(inputId, 1);
                        };
                        
                        controlsContainer.appendChild(minusBtn);
                        controlsContainer.appendChild(input);
                        controlsContainer.appendChild(plusBtn);
                        
                        sizeInputs.appendChild(sizeLabel);
                        sizeInputs.appendChild(controlsContainer);
                    });
                    
                    sizeCell.appendChild(sizeInputs);
                    row.appendChild(sizeCell);
                });
                
                // خلية الإجمالي
                const totalCell = document.createElement('td');
                totalCell.className = 'total-cell';
                totalCell.id = `sum-${rowIndex}`;
                totalCell.textContent = calculateRowTotal(rowIndex);
                row.appendChild(totalCell);
                
                tbody.appendChild(row);
            });
            
            // حساب الإجمالي الأولي
            calculateTotals();
        }
        
        // تعديل الكمية باستخدام أزرار الزائد والناقص
        function adjustQuantity(inputId, change) {
            const input = document.getElementById(inputId);
            if (!input) return;
            
            let currentValue = parseInt(input.value) || 0;
            let newValue = currentValue + change;
            
            if (newValue < 0) newValue = 0;
            
            input.value = newValue;
            
            // تفعيل الأحداث
            input.dispatchEvent(new Event('input', { bubbles: true }));
            input.dispatchEvent(new Event('change', { bubbles: true }));
        }
        
        // معالجة إدخال الكمية
        function handleQuantityInput(event) {
            const input = event.target;
            let value = parseInt(input.value) || 0;
            
            if (value < 0) {
                value = 0;
                input.value = 0;
            }
            
            // تحديث الإجمالي في الوقت الحقيقي
            const rowIndex = input.dataset.row;
            updateRowTotal(rowIndex);
            
            // تحديث الإجمالي الكلي
            calculateTotals();
            
            // حفظ البيانات
            saveData();
        }
        
        // تحديث إجمالي الصف
        function updateRowTotal(rowIndex) {
            let rowSum = 0;
            
            sizes.forEach(size => {
                subSizes.forEach(subSize => {
                    const input = document.getElementById(`qty-${rowIndex}-${size}-${subSize}`);
                    if (input) {
                        rowSum += parseInt(input.value) || 0;
                    }
                });
            });
            
            document.getElementById(`sum-${rowIndex}`).textContent = rowSum;
            return rowSum;
        }
        
        // حساب إجمالي الصف
        function calculateRowTotal(rowIndex) {
            let rowSum = 0;
            sizes.forEach(size => {
                subSizes.forEach(subSize => {
                    const savedValue = appState.quantities[`qty-${rowIndex}-${size}-${subSize}`] || 0;
                    rowSum += parseInt(savedValue) || 0;
                });
            });
            return rowSum;
        }
        
        // حساب الإجماليات الكلية
        function calculateTotals() {
            let grandTotal = 0;
            
            itemsData.forEach((_, rowIndex) => {
                const rowSum = updateRowTotal(rowIndex);
                grandTotal += rowSum;
            });
            
            document.getElementById('grandTotal').textContent = grandTotal.toLocaleString('ar-EG');
        }
        
        // إعداد مستمعي الأحداث
        function setupEventListeners() {
            // حفظ البيانات عند تغيير الحقول
            const inputs = ['custName', 'custAddress', 'repName', 'custPhone'];
            inputs.forEach(id => {
                const element = document.getElementById(id);
                if (element) {
                    element.addEventListener('input', function() {
                        saveData();
                        validateRequiredFields();
                    });
                    element.addEventListener('change', function() {
                        saveData();
                        validateRequiredFields();
                    });
                    element.addEventListener('blur', validateRequiredFields);
                }
            });
            
            // تحسين إدخال الأرقام على الجوال
            document.querySelectorAll('.quantity-input').forEach(input => {
                input.addEventListener('touchstart', function(e) {
                    e.stopPropagation();
                });
            });
            
            // إغلاق النوافذ المنبثقة عند النقر خارجها
            document.getElementById('editItemModal').addEventListener('click', function(e) {
                if (e.target === this) {
                    closeEditItemModal();
                }
            });
            
            // إغلاق خيارات الواتساب عند النقر خارجها
            document.addEventListener('click', function(e) {
                const whatsappOptions = document.getElementById('whatsappOptions');
                const whatsappBtn = document.querySelector('.btn-whatsapp');
                
                if (whatsappBtn && whatsappOptions && !whatsappBtn.contains(e.target) && !whatsappOptions.contains(e.target)) {
                    whatsappOptions.classList.remove('show');
                }
            });
        }
        
        // التحقق من الحقول المطلوبة
        function validateRequiredFields() {
            const requiredFields = [
                {id: 'custName', name: 'اسم العميل'},
                {id: 'custAddress', name: 'العنوان'},
                {id: 'repName', name: 'اسم المندوب'}
            ];
            
            let allValid = true;
            
            requiredFields.forEach(field => {
                const element = document.getElementById(field.id);
                const value = element ? element.value.trim() : '';
                
                if (!value) {
                    allValid = false;
                    element.style.borderColor = '#f44336';
                    element.style.backgroundColor = '#ffebee';
                } else {
                    element.style.borderColor = '#4caf50';
                    element.style.backgroundColor = '#e8f5e9';
                }
            });
            
            return allValid;
        }
        
        // حفظ البيانات
        function saveData() {
            appState.customerName = document.getElementById('custName').value.trim();
            appState.customerAddress = document.getElementById('custAddress').value.trim();
            appState.representative = document.getElementById('repName').value.trim();
            appState.phone = document.getElementById('custPhone').value.trim();
            appState.lastSave = new Date().toISOString();
            
            // حفظ الكميات
            appState.quantities = {};
            itemsData.forEach((_, rowIndex) => {
                sizes.forEach(size => {
                    subSizes.forEach(subSize => {
                        const inputId = `qty-${rowIndex}-${size}-${subSize}`;
                        const input = document.getElementById(inputId);
                        if (input) {
                            appState.quantities[inputId] = input.value || '';
                        }
                    });
                });
            });
            
            // حفظ الأصناف المخصصة
            appState.customItems = itemsData.filter(item => item.isCustom);
            
            // الحفظ في localStorage
            localStorage.setItem('makkam_order_system_final', JSON.stringify(appState));
        }
        
        // تحميل البيانات المحفوظة
        function loadSavedData() {
            const saved = localStorage.getItem('makkam_order_system_final');
            if (saved) {
                try {
                    appState = JSON.parse(saved);
                    
                    // تعيين بيانات العميل
                    document.getElementById('custName').value = appState.customerName || '';
                    document.getElementById('custAddress').value = appState.customerAddress || '';
                    document.getElementById('repName').value = appState.representative || '';
                    document.getElementById('custPhone').value = appState.phone || '';
                    
                    // إضافة الأصناف المخصصة المحفوظة
                    if (appState.customItems && Array.isArray(appState.customItems)) {
                        // الاحتفاظ بالأصناف الأساسية وإضافة المخصصة
                        const defaultItems = itemsData.filter(item => !item.isCustom);
                        itemsData = [...defaultItems, ...appState.customItems];
                    }
                    
                } catch (e) {
                    console.error('خطأ في تحميل البيانات:', e);
                }
            }
        }
        
        // إعادة تعيين النموذج
        function resetForm() {
            if (confirm('هل أنت متأكد من إعادة تعيين النموذج؟ سيتم حذف جميع البيانات المدخلة.')) {
                // مسح الحقول
                document.getElementById('custName').value = '';
                document.getElementById('custAddress').value = '';
                document.getElementById('repName').value = '';
                document.getElementById('custPhone').value = '';
                
                // مسح الكميات
                itemsData.forEach((_, rowIndex) => {
                    sizes.forEach(size => {
                        subSizes.forEach(subSize => {
                            const input = document.getElementById(`qty-${rowIndex}-${size}-${subSize}`);
                            if (input) input.value = '';
                        });
                    });
                });
                
                // إعادة الحساب
                calculateTotals();
                
                // إعادة التحقق من الحقول
                validateRequiredFields();
                
                showStatus('تم إعادة تعيين النموذج بنجاح', 'success');
            }
        }
        
        // إظهار رسالة الحالة
        function showStatus(message, type = 'info', duration = 5000) {
            const statusBar = document.getElementById('statusBar');
            const statusIcon = document.getElementById('statusIcon');
            const statusMessage = document.getElementById('statusMessage');
            
            // تعيين الرسالة
            statusMessage.textContent = message;
            
            // تعيين النوع (لون)
            let iconClass, barColor;
            switch (type) {
                case 'success':
                    iconClass = 'fas fa-check-circle';
                    barColor = '#4caf50';
                    break;
                case 'error':
                    iconClass = 'fas fa-exclamation-circle';
                    barColor = '#f44336';
                    break;
                case 'warning':
                    iconClass = 'fas fa-exclamation-triangle';
                    barColor = '#ff9800';
                    break;
                default:
                    iconClass = 'fas fa-info-circle';
                    barColor = '#2196f3';
            }
            
            statusIcon.innerHTML = `<i class="${iconClass}"></i>`;
            statusBar.style.borderRight = `4px solid ${barColor}`;
            
            // إظهار الشريط
            statusBar.classList.add('show');
            
            // إخفاء تلقائي بعد المدة
            if (duration > 0) {
                setTimeout(() => {
                    statusBar.classList.remove('show');
                }, duration);
            }
        }
        
        // إخفاء شريط الحالة
        function hideStatus() {
            document.getElementById('statusBar').classList.remove('show');
        }
        
        // ========== وظائف إدارة الأصناف ==========
        
        // فتح نافذة إدارة الأصناف
        function openEditItemModal(itemIndex) {
            const modal = document.getElementById('editItemModal');
            const title = document.getElementById('modalTitle');
            const nameInput = document.getElementById('editItemName');
            const codeInput = document.getElementById('editItemCode');
            const indexInput = document.getElementById('editItemIndex');
            
            // إعادة تعيين خيارات الألوان
            document.querySelectorAll('.color-option').forEach(option => {
                option.style.border = '2px solid transparent';
            });
            
            if (itemIndex === -1) {
                // وضع الإضافة
                title.innerHTML = '<i class="fas fa-plus-circle"></i> إضافة صنف جديد';
                nameInput.value = '';
                codeInput.value = '';
                indexInput.value = '-1';
                
                // اختيار أول لون افتراضي
                selectColor('gradient-1');
            } else {
                // وضع التعديل
                const item = itemsData[itemIndex];
                title.innerHTML = '<i class="fas fa-edit"></i> تعديل الصنف';
                nameInput.value = item.name;
                codeInput.value = item.code;
                indexInput.value = itemIndex;
                
                // اختيار لون الصنف الحالي
                selectColor(item.colorClass);
            }
            
            modal.style.display = 'flex';
            nameInput.focus();
        }
        
        // إغلاق نافذة إدارة الأصناف
        function closeEditItemModal() {
            document.getElementById('editItemModal').style.display = 'none';
        }
        
        // اختيار لون
        function selectColor(colorClass) {
            document.querySelectorAll('.color-option').forEach(option => {
                option.style.border = '2px solid transparent';
                if (option.dataset.color === colorClass) {
                    option.style.border = '2px solid #1a237e';
                }
            });
