        <!-- أزرار التحكم -->
        <div class="action-buttons">
            <div class="buttons-container">
                <button class="action-btn btn-add-item" onclick="openEditItemModal(-1)">
                    <i class="fas fa-plus-circle"></i>
                    إضافة/تعديل أصناف
                </button>
                
                <button class="action-btn btn-pdf" onclick="generatePDF()">
                    <i class="fas fa-file-pdf"></i>
                    تصدير PDF مفصل
                </button>
                
                <div class="whatsapp-btn-container">
                    <button class="action-btn btn-whatsapp" onclick="toggleWhatsAppOptions()">
                        <i class="fab fa-whatsapp"></i>
                        إرسال الطلب
                    </button>
                    <div class="whatsapp-options" id="whatsappOptions">
                        <button class="whatsapp-option" onclick="shareToWhatsApp('', 'customer')">
                            <i class="fas fa-user"></i> إرسال للعميل
                        </button>
                        <button class="whatsapp-option" onclick="shareToWhatsApp('', 'warehouse')">
                            <i class="fas fa-warehouse"></i> إرسال للمستودع
                        </button>
                    </div>
                </div>
                
                <button class="action-btn btn-reset" onclick="resetForm()">
                    <i class="fas fa-redo"></i>
                    إعادة تعيين
                </button>
            </div>
        </div>
