                message += `📍 *العنوان:* ${customerAddress}\n`;
                message += `👨‍💼 *المندوب:* ${senderRep}\n`;
                message += `📅 *التاريخ:* ${date}\n`;
                message += `\n📊 *تفاصيل الطلب للتجهيز:*\n`;
            }
            
            message += `-----------------\n`;
            
            // إضافة تفاصيل المنتجات
            itemsData.forEach((item, rowIndex) => {
                const rowSum = calculateRowTotal(rowIndex);
                if (rowSum > 0) {
                    message += `✅ ${item.name}: ${rowSum} قطعة\n`;
                    
                    // إضافة تفاصيل المقاسات
                    sizes.forEach(size => {
                        let sizeDetails = [];
                        subSizes.forEach(subSize => {
                            const input = document.getElementById(`qty-${rowIndex}-${size}-${subSize}`);
                            if (input && parseInt(input.value) > 0) {
                                sizeDetails.push(`${subSize}: ${input.value}`);
                            }
                        });
                        
                        if (sizeDetails.length > 0) {
                            message += `   📏 ${size}: ${sizeDetails.join(' | ')}\n`;
                        }
                    });
                }
            });
            
            message += `\n💰 *الإجمالي الكلي:* ${grandTotal} قطعة\n`;
            
            if (type === 'customer') {
                message += `\nشكراً لثقتكم بمؤسسة المقام التجارية`;
            } else {
                message += `\n📍 *مطلوب التجهيز الفوري*`;
            }
            
            const encodedMessage = encodeURIComponent(message);
            let whatsappUrl;
            
            if (type === 'customer' && phoneNumber) {
                whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodedMessage}`;
            } else if (type === 'customer') {
                whatsappUrl = `https://wa.me/?text=${encodedMessage}`;
            } else {
                // للمستودع، نفتح الواتساب بدون رقم محدد
                whatsappUrl = `https://wa.me/?text=${encodedMessage}`;
            }
            
            window.open(whatsappUrl, '_blank');
            document.getElementById('whatsappOptions').classList.remove('show');
            
            showStatus('جاري فتح واتساب للمشاركة...', 'info');
        }
    </script>
</body>
</html>
