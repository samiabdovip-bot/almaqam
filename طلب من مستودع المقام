        // حفظ الصنف (إضافة أو تعديل)
        function saveItem() {
            const name = document.getElementById('editItemName').value.trim();
            const code = document.getElementById('editItemCode').value.trim();
            const colorClass = document.getElementById('selectedColor').value;
            const itemIndex = parseInt(document.getElementById('editItemIndex').value);
            
            if (!name || !code) {
                showStatus('يرجى إدخال اسم الصنف ورمزه', 'error');
                return;
            }
            
            // التحقق من عدم تكرار الرمز (باستثناء الصنف الحالي في وضع التعديل)
            if (itemsData.some((item, index) => item.code === code && index !== itemIndex)) {
                showStatus('رمز الصنف موجود مسبقاً، يرجى استخدام رمز آخر', 'error');
                return;
            }
            
            if (itemIndex === -1) {
                // إضافة صنف جديد
                const newItem = {
                    name: name,
                    code: code,
                    colorClass: colorClass,
                    isCustom: true
                };
                
                itemsData.push(newItem);
                showStatus(`تم إضافة الصنف "${name}" بنجاح`, 'success');
            } else {
                // تعديل صنف موجود
                itemsData[itemIndex].name = name;
                itemsData[itemIndex].code = code;
                itemsData[itemIndex].colorClass = colorClass;
                itemsData[itemIndex].isCustom = true;
                
                showStatus(`تم تحديث الصنف "${name}" بنجاح`, 'success');
            }
            
            // إعادة بناء الجدول
            buildTable();
            
            // حفظ البيانات
            saveData();
            
            // إغلاق النافذة
            closeEditItemModal();
        }
        
        // حذف صنف
        function removeItem(rowIndex) {
            const item = itemsData[rowIndex];
            
            if (confirm(`هل أنت متأكد من حذف الصنف "${item.name}"؟`)) {
                // حذف الصنف من المصفوفة
                itemsData.splice(rowIndex, 1);
                
                // حذف الكميات المرتبطة بهذا الصنف من appState
                const prefix = `qty-${rowIndex}-`;
                for (const key in appState.quantities) {
                    if (key.startsWith(prefix)) {
                        delete appState.quantities[key];
                    }
                }
                
                // إعادة ترقيم الكميات للصفوف اللاحقة
                const newQuantities = {};
                for (const key in appState.quantities) {
                    const parts = key.split('-');
                    const oldRowIndex = parseInt(parts[1]);
                    
                    if (oldRowIndex > rowIndex) {
                        // تعديل الفهرس
                        parts[1] = (oldRowIndex - 1).toString();
                        const newKey = parts.join('-');
                        newQuantities[newKey] = appState.quantities[key];
                    } else if (oldRowIndex < rowIndex) {
                        // الاحتفاظ بنفس المفتاح
                        newQuantities[key] = appState.quantities[key];
                    }
                }
                
                appState.quantities = newQuantities;
                
                // إعادة بناء الجدول
                buildTable();
                
                // حفظ البيانات
                saveData();
                
                showStatus(`تم حذف الصنف "${item.name}" بنجاح`, 'success');
            }
        }
        
        // ========== تصدير PDF مفصّل - الحل المحسن ==========
        async function generatePDF() {
            const customerName = document.getElementById('custName').value.trim();
            const customerAddress = document.getElementById('custAddress').value.trim();
            const representative = document.getElementById('repName').value.trim();
            
            // التحقق من البيانات الإلزامية
            if (!customerName || !customerAddress || !representative) {
                showStatus('يرجى تعبئة جميع الحقول الإلزامية قبل التصدير', 'error');
                
                // تسليط الضوء على الحقول الفارغة
                validateRequiredFields();
                
                // التركيز على أول حقل فارغ
                if (!customerName) {
                    document.getElementById('custName').focus();
                } else if (!customerAddress) {
                    document.getElementById('custAddress').focus();
                } else {
                    document.getElementById('repName').focus();
                }
                
                return;
            }
            
            const grandTotal = document.getElementById('grandTotal').textContent;
            if (grandTotal === '0') {
                showStatus('يرجى إدخال كميات قبل التصدير', 'error');
                return;
            }
            
            showStatus('جاري إنشاء ملف PDF مفصّل...', 'info');
            
            try {
                // إنشاء محتوى PDF مفصّل
                const pdfContent = createDetailedPDFContent();
                
                // إنشاء عنصر مؤقت للتصدير
                const exportElement = document.createElement('div');
                exportElement.id = 'pdf-export';
                exportElement.style.cssText = `
                    position: absolute;
                    left: -9999px;
                    top: 0;
                    width: 794px; /* A4 عرض */
                    background: white;
                    padding: 25px 30px;
                    direction: rtl;
                    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                    box-sizing: border-box;
                    line-height: 1.4;
                    font-size: 12px;
                `;
                
                exportElement.innerHTML = pdfContent;
                document.body.appendChild(exportElement);
                
                // الانتظار حتى يتم تحميل جميع الصور والخطوط
                await new Promise(resolve => setTimeout(resolve, 300));
                
                // الحصول على ارتفاع المحتوى الحقيقي
                const contentHeight = exportElement.scrollHeight;
                const pageHeightPx = 1123; // A4 ارتفاع بالبكسل (297مم × 3.78)
                
                // حساب عدد الصفحات المطلوبة
                const numPages = Math.ceil(contentHeight / pageHeightPx);
                
                // إنشاء PDF
                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF({
                    orientation: 'portrait',
                    unit: 'mm',
                    format: 'a4',
                    compress: true
                });
                
                // هوامش الصفحة
                const margin = 10;
                const pageWidth = pdf.internal.pageSize.getWidth();
                const pageHeightMM = pdf.internal.pageSize.getHeight();
                const contentWidth = pageWidth - (2 * margin);
                
                showStatus(`جاري إنشاء ${numPages} صفحة...`, 'info');
                
                // تكرار لكل صفحة
                for (let pageNum = 0; pageNum < numPages; pageNum++) {
                    if (pageNum > 0) {
                        pdf.addPage();
                    }
                    
                    // حساب الجزء المراد عرضه من المحتوى
                    const clipY = pageNum * pageHeightPx;
                    const clipHeight = Math.min(pageHeightPx, contentHeight - clipY);
                    
                    // استخدام html2canvas مع خيارات محسنة
                    const canvas = await html2canvas(exportElement, {
                        scale: 1.5,
                        useCORS: true,
                        logging: false,
                        backgroundColor: '#ffffff',
                        allowTaint: true,
                        width: 794,
                        height: clipHeight,
                        windowWidth: 794,
                        windowHeight: clipHeight,
                        y: clipY,
                        scrollX: 0,
                        scrollY: clipY,
                        onclone: function(clonedDoc) {
                            const clonedElement = clonedDoc.getElementById('pdf-export');
                            if (clonedElement) {
                                clonedElement.style.transform = `translateY(-${clipY}px)`;
                            }
                        }
                    });
                    
                    // إضافة الصورة إلى PDF
                    const imgData = canvas.toDataURL('image/jpeg', 0.92);
                    const imgWidth = contentWidth;
                    const imgHeight = (canvas.height * imgWidth) / canvas.width;
                    
                    pdf.addImage(imgData, 'JPEG', margin, margin, imgWidth, imgHeight);
                    
                    // إضافة تذييل الصفحة
                    pdf.setFontSize(8);
                    pdf.setTextColor(100);
                    pdf.text(
                        `صفحة ${pageNum + 1} من ${numPages} - مؤسسة المقام التجارية - ${new Date().toLocaleDateString('ar-EG')}`,
                        pageWidth / 2,
                        pageHeightMM - 5,
                        { align: 'center' }
                    );
                    
                    // تحديث حالة التقدم
                    if (numPages > 1) {
                        showStatus(`جاري إنشاء الصفحة ${pageNum + 1} من ${numPages}...`, 'info', 1000);
                    }
                }
                
                // إزالة العنصر المؤقت
                document.body.removeChild(exportElement);
                
                // حفظ الملف
                const fileName = `طلب_توريد_${customerName.replace(/\s+/g, '_')}_${new Date().toISOString().slice(0,10)}.pdf`;
                pdf.save(fileName);
                
                showStatus(`تم إنشاء ملف PDF ${numPages} صفحة بنجاح`, 'success');
                
            } catch (error) {
                console.error('خطأ في إنشاء PDF:', error);
                showStatus('حدث خطأ في إنشاء PDF. يرجى المحاولة مرة أخرى', 'error');
                
                // تنظيف العنصر المؤقت في حالة الخطأ
                const exportElement = document.getElementById('pdf-export');
                if (exportElement) {
                    document.body.removeChild(exportElement);
                }
            }
        }
        
